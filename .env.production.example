# Production Environment Configuration
# Copy this to .env.production and fill in your values

# Sentry Error Tracking
VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# Rollbar Error Tracking
VITE_ROLLBAR_ACCESS_TOKEN=your-rollbar-access-token

# Application Environment
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_URL=https://indexer.yourdomain.com

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CRASH_REPORTING=true
VITE_ENABLE_BACKUPS=true
